---
import Layout from './Layout.astro';
import type { BreadcrumbItem } from '@utils/content';
import { PageTopbar, TableOfContents } from '@components/patterns';
import { Button, Container } from '@/components/primitives';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs: BreadcrumbItem[];
  headings?: Heading[];
  editUrl?: string;
  isTranslation?: boolean;
}

const {
  title,
  description,
  breadcrumbs,
  headings = [],
  editUrl,
  isTranslation = false,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={title} description={description}>
  <Container>
    <PageTopbar breadcrumbs={breadcrumbs}>
      {
        editUrl && (
          <Button as="a" variant="secondary" size="sm" href={editUrl}>
            <Icon
              name={isTranslation ? 'fluent:translate-20-regular' : 'github'}
              aria-hidden="true"
            />
            {isTranslation ? t('page.translateThis') : t('page.editOnGitHub')}
          </Button>
        )
      }
    </PageTopbar>

    <div class="doc-layout">
      <article>
        <slot />
      </article>
      <TableOfContents headings={headings} class="doc-toc" />
    </div>
  </Container>
</Layout>

<style>
  .doc-layout {
    display: flex;
    flex-direction: column;

    @media (--md-up) {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-10);
    }
  }

  .doc-layout > article {
    min-width: 0;
    flex: 1;
    order: 1;
  }

  .doc-toc {
    flex-shrink: 0;
    order: 0;
    background-color: var(--color-bg-primary);
    position: sticky;
    top: var(--space-14);
    padding: var(--space-6) 0 0;

    @media (--md-up) {
      order: 1;
      width: var(--size-56);
      max-height: calc(100vh - var(--space-24));
      overflow-y: auto;
    }
  }
</style>
