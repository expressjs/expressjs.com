---
import { getCollection, render } from 'astro:content';
import DocLayout from '@layouts/DocLayout.astro';
import type { MenuSection } from '@config/menu';

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return docs
    .filter((doc) => doc.id.startsWith('en/'))
    .map((doc) => {
      // Parse the path: en/section/file.md -> section, slug
      const pathParts = doc.id.split('/');
      const section = pathParts[1] as MenuSection;
      const slug = pathParts
        .slice(2)
        .join('/')
        .replace(/\.mdx?$/, '');

      return {
        params: {
          section,
          slug,
        },
        props: { doc },
      };
    });
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const { title, description, menu } = doc.data;
---

<DocLayout title={title} description={description} section={menu as MenuSection}>
  <Content />
</DocLayout>
