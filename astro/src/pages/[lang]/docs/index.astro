---
import Layout from '@layouts/Layout.astro';
import { menuSections, type MenuSection } from '@config/menu';
import { getDocsBySection } from '@utils/content';
import { Container } from '@components/primitives';

const sections = Object.entries(menuSections);

import { getLangFromUrl } from '@i18n/utils';
import { languages } from '@i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Express Documentation">
  <Container>
    <h1>Express Documentation</h1>

    <div>
      {
        sections.map(async ([key, label]) => {
          const docs = await getDocsBySection(key as MenuSection, lang);
          const firstDocs = docs.slice(0, 5);

          return (
            <section>
              <h2>{label}</h2>
              <ul>
                {firstDocs.map((doc) => {
                  const slug = doc.id.replace(`${lang}/${key}/`, '').replace(/\.mdx?$/, '');
                  return (
                    <li>
                      <a href={`/${lang}/${key}/${slug}`}>{doc.data.title}</a>
                    </li>
                  );
                })}
                {docs.length > 5 && (
                  <li class="view-all">
                    <a href={`/${lang}/${key}`}>View all →</a>
                  </li>
                )}
              </ul>
            </section>
          );
        })
      }
    </div>
  </Container>
</Layout>
