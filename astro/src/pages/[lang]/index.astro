---
import { Hero } from '@components/patterns';
import Layout from '@layouts/Layout.astro';
import { languages } from '@i18n/locales';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}
---

<Layout>
  <Hero
    videoSrc="/videos/hero-background-opt.mp4"
    videoSrcMobile="/videos/hero-background-opt.mp4"
    videoSrcLight="/videos/hero-background-light-opt.mp4"
    videoSrcMobileLight="/videos/hero-background-light-opt.mp4"
    posterSrc="/hero-poster.jpg"
    posterSrcLight="/hero-poster-light.jpg"
  />
</Layout>
