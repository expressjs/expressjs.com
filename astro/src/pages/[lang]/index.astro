---
import { Hero } from '@components/patterns';
import Layout from '@layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { languages } from '@i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
  <Hero
    videoSrc="/videos/hero-background.mp4"
    videoSrcMobile="/videos/hero-background.mp4"
    videoSrcLight="/videos/hero-background-light.mp4"
    videoSrcMobileLight="/videos/hero-background-light.mp4"
    posterSrc="/hero-poster.jpg"
    disableVideoOnMobile={true}
  />
</Layout>
