---
/**
 * Design System Foundations Demo
 *
 * A single-page demo of all primitive components and tokens.
 */
import { Icon } from 'astro-icon/components';
import Layout from '@layouts/Layout.astro';
import {
  Container,
  Grid,
  Col,
  Flex,
  H1,
  H2,
  H3,
  H4,
  H5,
  Body,
  BodyMd,
  BodySm,
  BodyXs,
  Code,
} from '@components/primitives';
import { ThemeSwitcher } from '@components/patterns';
import { getLangFromUrl } from '@i18n/utils';
import { languages } from '@i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Design System Foundations">
  <Container as="main">
    <header class="ds-header">
      <H1>Design System Foundations</H1>
      <H5 color="secondary"> A living reference of all primitive components, tokens, and patterns. </H5>
    </header>

    <nav class="ds-nav">
      <ul class="ds-nav__list">
        <li><a href={`/${lang}`} class="ds-nav__link">← Home</a></li>
        <li><a href="#typography" class="ds-nav__link">Typography</a></li>
        <li><a href="#iconography" class="ds-nav__link">Iconography</a></li>
        <li><a href="#colors" class="ds-nav__link">Colors</a></li>
        <li><a href="#spacing" class="ds-nav__link">Spacing</a></li>
        <li><a href="#grid" class="ds-nav__link">Grid</a></li>
        <li><a href="#breakpoints" class="ds-nav__link">Breakpoints</a></li>
        <li><ThemeSwitcher /></li>
      </ul>
    </nav>

    <!-- TYPOGRAPHY -->
    <section id="typography" class="ds-section">
      <H2>Typography</H2>

      <div class="ds-subsection">
        <H3>Headings</H3>
        <div class="ds-demo">
          <H1>Heading 1 — Page titles</H1>
          <H2>Heading 2 — Section titles</H2>
          <H3>Heading 3 — Subsections</H3>
          <H4>Heading 4 — Minor headings</H4>
          <H5>Heading 5 — Lead/intro paragraph text</H5>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Body Text</H3>
        <div class="ds-demo">
          <Body
            ><b>Body</b> — Default paragraph text. This is the standard size for documentation content and general reading.</Body
          >
          <BodyMd
            ><b>Body Medium</b> — Slightly smaller than default body. Good for sidebars and secondary content.</BodyMd
          >
          <p>
            <BodySm
              ><b>Body Small</b> — Secondary text, captions, and helper text. Used for metadata and less prominent content.</BodySm
            >
          </p>
          <p><BodyXs><b>Body Extra Small</b> — Fine print, legal text, and timestamps.</BodyXs></p>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Code</H3>
        <div class="ds-demo">
          <Code>const express = require('express');</Code>
          <Body>Inline code: Use <Code as="code">npm install express</Code> to install.</Body>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Weights</H3>
        <div class="ds-demo ds-demo--row">
          <Body weight="light">Light 300</Body>
          <Body weight="normal">Normal 400</Body>
          <Body weight="medium">Medium 500</Body>
          <Body weight="semibold">Semibold 600</Body>
          <Body weight="bold">Bold 700</Body>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Polymorphic Rendering</H3>
        <div class="ds-demo">
          <H1 as="h2">H1 styled, rendered as h2</H1>
          <Body as="span">Body text rendered as span (inline)</Body>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Type Scale</H3>

        <div class="ds-type-scale">
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-6xl); line-height: 1;">Aa</span>
            <BodyXs>6xl (54px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-5xl); line-height: 1;">Aa</span>
            <BodyXs>5xl (45px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-4xl); line-height: 1;">Aa</span>
            <BodyXs>4xl (36px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-3xl); line-height: 1;">Aa</span>
            <BodyXs>3xl (30px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-2xl); line-height: 1;">Aa</span>
            <BodyXs>2xl (24px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-xl); line-height: 1;">Aa</span>
            <BodyXs>xl (20px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-lg); line-height: 1;">Aa</span>
            <BodyXs>lg (18px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-base); line-height: 1;">Aa</span>
            <BodyXs>base (16px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-sm); line-height: 1;">Aa</span>
            <BodyXs>sm (14px)</BodyXs>
          </div>
          <div class="ds-type-item">
            <span style="font-size: var(--font-size-xs); line-height: 1;">Aa</span>
            <BodyXs>xs (12px)</BodyXs>
          </div>
        </div>
      </div>
    </section>

    <!-- ICONS -->
    <section id="iconography" class="ds-section">
      <H2>Iconography</H2>
      <BodyMd color="secondary">
        Icons are provided by <Code as="code">astro-icon</Code>, a well-supported and officially recommended package for
        Astro that gives access to 200,000+ icons from various icon sets. We primarily use Phosphor Icons (prefix <Code
          as="code">ph:</Code
        >).
      </BodyMd>

      <div class="ds-subsection">
        <H3>Examples</H3>
        <div class="ds-demo ds-demo--row">
          <Icon name="ph:airplane" size="24" color="var(--color-icon-primary)" />
          <Icon name="ph:anchor" size="24" color="var(--color-icon-primary)" />
          <Icon name="ph:check-circle" size="24" color="var(--color-icon-primary)" />
          <Icon name="ph:warning" size="24" color="var(--color-icon-primary)" />
          <Icon name="ph:info" size="24" color="var(--color-icon-primary)" />
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Usage</H3>
        <div class="ds-demo ds-demo--col">
          <Code>{'import { Icon } from "astro-icon/components";'}</Code>
          <Code>{'<Icon name="ph:airplane" size="24" />'}</Code>
          <Code>{'<Icon name="ph:check" color="var(--color-icon-primary)" />'}</Code>
        </div>
        <BodySm color="secondary" style="margin-top: var(--space-3);">
          Browse available icons at <a href="https://icon-sets.iconify.design/ph/" target="_blank" rel="noopener"
            >Phosphor Icons</a
          > or explore other icon sets at <a href="https://icon-sets.iconify.design/" target="_blank" rel="noopener"
            >Iconify</a
          >.
        </BodySm>
      </div>
    </section>

    <!-- COLOR TOKENS -->
    <section id="colors" class="ds-section">
      <H2>Color Tokens</H2>

      <div class="ds-subsection">
        <H3>Primitive tokens</H3>
        <div class="ds-color-grid">
          <div class="ds-color-swatch" style="background: var(--white);"><span>white</span></div>
          <div class="ds-color-swatch" style="background: var(--gray-50);">
            <span>gray-50</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-100);">
            <span>gray-100</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-200);">
            <span>gray-200</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-300);">
            <span>gray-300</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-400);">
            <span>gray-400</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-500);">
            <span>gray-500</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-600);">
            <span>gray-600</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-700);">
            <span>gray-700</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-800);">
            <span>gray-800</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-900);">
            <span>gray-900</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--gray-950);">
            <span>gray-950</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--black);"><span>black</span></div>
        </div>

        <div class="ds-color-grid">
          <div class="ds-color-swatch" style="background: var(--sky-50);"><span>sky-50</span></div>
          <div class="ds-color-swatch" style="background: var(--sky-500);">
            <span>sky-500</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--sky-700);">
            <span>sky-700</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--sky-800);">
            <span>sky-800</span>
          </div>
        </div>

        <div class="ds-color-grid">
          <div class="ds-color-swatch" style="background: var(--green-50);">
            <span>green-50</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--green-300);">
            <span>green-300</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--green-500);">
            <span>green-500</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--green-700);">
            <span>green-700</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--green-900);">
            <span>green-900</span>
          </div>
        </div>

        <div class="ds-color-grid">
          <div class="ds-color-swatch" style="background: var(--amber-50);">
            <span>amber-50</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--amber-300);">
            <span>amber-300</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--amber-500);">
            <span>amber-500</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--amber-600);">
            <span>amber-600</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--amber-700);">
            <span>amber-700</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--amber-900);">
            <span>amber-900</span>
          </div>
        </div>

        <div class="ds-color-grid">
          <div class="ds-color-swatch" style="background: var(--red-50);">
            <span>red-50</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--red-300);">
            <span>red-300</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--red-500);">
            <span>red-500</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--red-600);">
            <span>red-600</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--red-700);">
            <span>red-700</span>
          </div>
          <div class="ds-color-swatch" style="background: var(--red-900);">
            <span>red-900</span>
          </div>
        </div>
      </div>

      <div class="ds-subsection">
        <div class="ds-subsection">
          <H3>Semantic tokens</H3>
          <div class="ds-color-grid ds-color-grid--large">
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-primary);">
              <span>bg-primary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-secondary);">
              <span>bg-secondary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-tertiary);">
              <span>bg-tertiary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-inverse);">
              <span>bg-inverse</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-inactive);">
              <span>bg-inactive</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-success);">
              <span>bg-success</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-warning);">
              <span>bg-warning</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-bg-error);">
              <span>bg-error</span>
            </div>
          </div>
          <div class="ds-color-grid ds-color-grid--large">
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-primary);">
              <span>text-primary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-secondary);">
              <span>text-secondary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-tertiary);">
              <span>text-tertiary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-inverse);">
              <span>text-inverse</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-inactive);">
              <span>text-inactive</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-success);">
              <span>text-success</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-warning);">
              <span>text-warning</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-text-error);">
              <span>text-error</span>
            </div>
          </div>
          <!-- add section for border color tokens -->
          <div class="ds-color-grid ds-color-grid--large">
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-primary);">
              <span>border-primary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-secondary);">
              <span>border-secondary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-tertiary);">
              <span>border-tertiary</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-inverse);">
              <span>border-inverse</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-inactive);">
              <span>border-inactive</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-success);">
              <span>border-success</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-warning);">
              <span>border-warning</span>
            </div>
            <div class="ds-color-swatch ds-color-swatch--large" style="background: var(--color-border-error);">
              <span>border-error</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SPACING -->
    <section id="spacing" class="ds-section">
      <H2>Spacing</H2>

      <div class="ds-subsection">
        <H3>Scale</H3>
        <div class="ds-spacing-grid">
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-0.5); height: var(--space-0.5);"></div>
            <BodyXs>0.5 (2px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-1); height: var(--space-1);"></div>
            <BodyXs>1 (4px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-2); height: var(--space-2);"></div>
            <BodyXs>2 (8px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-3); height: var(--space-3);"></div>
            <BodyXs>3 (12px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-4); height: var(--space-4);"></div>
            <BodyXs>4 (16px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-6); height: var(--space-6);"></div>
            <BodyXs>6 (24px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-8); height: var(--space-8);"></div>
            <BodyXs>8 (32px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-12); height: var(--space-12);"></div>
            <BodyXs>12 (48px)</BodyXs>
          </div>
          <div class="ds-spacing-item">
            <div class="ds-spacing-box" style="width: var(--space-16); height: var(--space-16);"></div>
            <BodyXs>16 (64px)</BodyXs>
          </div>
        </div>
      </div>
    </section>

    <!-- GRID -->
    <section id="grid" class="ds-section">
      <H2>Grid & Layout</H2>
      <BodyMd color="secondary"> 12-column responsive grid system with Grid, Col, and Flex components. </BodyMd>

      <div class="ds-subsection">
        <H3>Grid Component</H3>
        <BodyMd color="secondary"> Responsive 12-column grid. Columns cascade from xs → md → lg. </BodyMd>
        <div class="ds-demo" style="margin-top: var(--space-4);">
          <Grid gap="4">
            <Col xs={12} md={6} lg={4}>
              <div class="ds-box">
                <BodySm>xs=12, md=6, lg=4</BodySm>
              </div>
            </Col>
            <Col xs={12} md={6} lg={4}>
              <div class="ds-box">
                <BodySm>xs=12, md=6, lg=4</BodySm>
              </div>
            </Col>
            <Col xs={12} md={12} lg={4}>
              <div class="ds-box">
                <BodySm>xs=12, md=12, lg=4</BodySm>
              </div>
            </Col>
          </Grid>
        </div>
        <div class="ds-demo ds-demo--col" style="margin-top: var(--space-4);">
          <Code>{'<Grid gap="4">'}</Code>
          <Code>{'  <Col xs={12} md={6} lg={4}>Content</Col>'}</Code>
          <Code>{'  <Col xs={12} md={6} lg={4}>Content</Col>'}</Code>
          <Code>{'</Grid>'}</Code>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Flex Component</H3>
        <BodyMd color="secondary">Flexbox layouts for 1D directional content.</BodyMd>
        <div class="ds-demo" style="margin-top: var(--space-4);">
          <Flex direction="row" gap="4" justify="between" align="center">
            <div class="ds-box" style="background: var(--sky-100); padding: var(--space-3);">
              <BodySm>Item 1</BodySm>
            </div>
            <div class="ds-box" style="padding: var(--space-3);">
              <BodySm>Item 2</BodySm>
            </div>
            <div class="ds-box" style="padding: var(--space-3);">
              <BodySm>Item 3</BodySm>
            </div>
          </Flex>
        </div>
        <div class="ds-demo ds-demo--col" style="margin-top: var(--space-4);">
          <Code>{'<Flex direction="row" gap="4" justify="between">'}</Code>
          <Code>{'  <div>Item 1</div>'}</Code>
          <Code>{'  <div>Item 2</div>'}</Code>
          <Code>{'</Flex>'}</Code>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Container</H3>
        <BodyMd color="secondary"> Centered, responsive content wrapper with max-width and padding. </BodyMd>
        <div class="ds-demo-container" style="margin-top: var(--space-4);">
          <Container>
            <div class="ds-box">
              <Body>Content centered with max-width: 1440px, width: 90-95%</Body>
            </div>
          </Container>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Utility Classes</H3>
        <div class="ds-demo ds-demo--col">
          <Code>.grid - Display grid</Code>
          <Code>.grid-cols-{'{1,2,3,4,6,12}'} - Grid template columns</Code>
          <Code>.col-span-{'{1,2,3,4,6,12,full}'} - Column span</Code>
          <Code>.flex - Display flex</Code>
          <Code>.flex-{'{row,col}'} - Flex direction</Code>
          <Code>.items-{'{start,center,end}'} - Align items</Code>
          <Code>.justify-{'{start,center,end,between}'} - Justify content</Code>
          <Code>.gap-{'{1,2,3,4,6,8}'} - Gap spacing</Code>
        </div>
      </div>
    </section>

    <!-- BREAKPOINTS -->
    <section id="breakpoints" class="ds-section">
      <H2>Breakpoints</H2>

      <div class="ds-demo">
        <div class="ds-breakpoint-indicator">
          <span class="ds-breakpoint ds-breakpoint--xs">Current: Mobile (xs) &lt; 768px</span>
          <span class="ds-breakpoint ds-breakpoint--md">Current: Tablet (md) 768px – 1439px</span>
          <span class="ds-breakpoint ds-breakpoint--lg">Current: Desktop (lg) ≥ 1440px</span>
        </div>
      </div>

      <div class="ds-subsection">
        <H3>Usage</H3>
        <div class="ds-demo ds-demo--col">
          <Code>@media (--xs) {'{ /* mobile only */ }'}</Code>
          <Code>@media (--md) {'{ /* tablet only */ }'}</Code>
          <Code>@media (--md-up) {'{ /* tablet and above */ }'}</Code>
          <Code>@media (--lg) {'{ /* desktop only */ }'}</Code>
          <Code>@media (--lg-down) {'{ /* desktop and below */ }'}</Code>
        </div>
      </div>
    </section>
  </Container>

  <style>
    /* Navigation */
    .ds-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--color-bg-primary);
      border-bottom: 1px solid var(--color-border-secondary);
      padding: var(--space-3) var(--space-4);
      margin-bottom: var(--space-8);
    }

