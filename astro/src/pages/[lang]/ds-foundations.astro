      <style>
        /* Navigation */
        .ds-nav {
          position: sticky;
          top: 60px;
          background: var(--color-bg-primary);
          border-bottom: 1px solid var(--color-border-secondary);
          padding: var(--space-3) var(--space-4);
          margin-bottom: var(--space-8);
        }

        .ds-nav__list {
          list-style: none;
          margin: 0;
          padding: 0;
          display: flex;
          align-items: center;
          gap: var(--space-1);
          overflow-x: auto;
          max-width: 1440px;
          margin-inline: auto;
        }

        .ds-nav__link {
          display: block;
          padding: var(--space-2) var(--space-3);
          font-size: var(--font-size-sm);
          color: var(--color-text-secondary);
          text-decoration: none;
          border-radius: 6px;
          white-space: nowrap;
          transition:
            background-color 0.15s ease,
            color 0.15s ease;
        }

        .ds-nav__link:hover {
          color: var(--color-text-primary);
          background: var(--color-bg-secondary);
        }

        /* Scroll offset for sticky nav */
        .ds-section {
          scroll-margin-top: var(--space-16);
        }

        .ds-header {
          padding: var(--space-12) 0;
        }

        .ds-section {
          margin-bottom: var(--space-16);
        }

        .ds-subsection {
          margin-top: var(--space-8);
        }

        .ds-demo {
          padding: var(--space-6);
          background: var(--color-bg-secondary);
          border-radius: 8px;
          margin-top: var(--space-4);
        }

        .ds-demo--col {
          display: flex;
          flex-direction: column;
          gap: var(--space-3);
        }

        .ds-demo--row {
          display: flex;
          flex-direction: row;
          flex-wrap: wrap;
          gap: var(--space-4);
        }

        .ds-demo-container {
          background: var(--color-bg-tertiary);
          padding: var(--space-4);
          margin-top: var(--space-4);
          border-radius: 8px;
        }

        .ds-box {
          background: var(--color-bg-secondary);
          padding: var(--space-4);
          border-radius: 8px;
          border: 1px dashed var(--color-border-primary);
        }

        /* Color Grid */
        .ds-color-grid {
          display: flex;
          flex-wrap: wrap;
          gap: var(--space-2);
          margin-top: var(--space-4);
        }

        .ds-color-grid--large {
          gap: var(--space-4);
        }

        .ds-color-swatch {
          width: 60px;
          height: 60px;
          border-radius: 8px;
          border: 1px solid var(--color-border-secondary);
          display: flex;
          align-items: flex-end;
          justify-content: center;
          padding: var(--space-1);
        }

        .ds-color-swatch span {
          font-size: var(--font-size-xxs);
          font-family: var(--font-family-mono);
          background: var(--color-bg-primary);
          padding: 0.1em 0.3em;
          border-radius: 3px;
        }

        .ds-color-swatch--large {
          width: 120px;
          height: 80px;
        }

        /* Spacing Grid */
        .ds-spacing-grid {
          display: flex;
          flex-wrap: wrap;
          align-items: flex-end;
          gap: var(--space-6);
          margin-top: var(--space-4);
        }

        .ds-spacing-item {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: var(--space-2);
        }

        .ds-spacing-box {
          background: var(--sky-500);
          border-radius: 2px;
        }

        /* Type Scale */
        .ds-type-scale {
          display: flex;
          flex-wrap: wrap;
          align-items: flex-end;
          gap: var(--space-8);
          margin-top: var(--space-4);
        }

        .ds-type-item {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: var(--space-2);
        }

        /* Breakpoint Indicator */
        .ds-breakpoint-indicator {
          display: flex;
          flex-direction: column;
          gap: var(--space-2);
        }

        .ds-breakpoint {
          padding: var(--space-3) var(--space-4);
          border-radius: 6px;
          font-family: var(--font-family-mono);
          font-size: var(--font-size-sm);
          display: none;
        }

        .ds-breakpoint--xs {
          background: var(--orange-50);
          color: var(--orange-700);
        }

        .ds-breakpoint--md {
          background: var(--sky-50);
          color: var(--sky-700);
        }

        .ds-breakpoint--lg {
          background: var(--green-50);
          color: var(--green-700);
        }

        @media (--xs-only) {
          .ds-breakpoint--xs {
            display: block;
          }
        }

        @media (--md-up) {
          .ds-breakpoint--md {
            display: block;
          }
        }

        @media (--lg-up) {
          .ds-breakpoint--lg {
            display: block;
          }
        }
      </style>
