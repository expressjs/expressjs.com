---
import { getCollection } from 'astro:content';
import DocLayout from '@layouts/DocLayout.astro';
import type { MenuSection } from '@config/menu';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('docs');

  const paths = pages.map((page) => {
    const [lang, ...slug] = page.id.split('/');
    const section = slug[0] as MenuSection;

    return {
      params: {
        lang,
        section,
        slug: slug.slice(1).join('/') || undefined,
      },
      props: { page },
    };
  });

  return paths;

  // return pages
  //   .filter((page) => page.id.startsWith('en/'))
  //   .map((page) => {
  //     // Parse the path: en/section/file.md -> section, slug
  //     const pathParts = page.id.split('/');
  //     const section = pathParts[1] as MenuSection;
  //     const slug = pathParts
  //       .slice(2)
  //       .join('/')
  //       .replace(/\.mdx?$/, '');

  //     return {
  //       params: {
  //         section,
  //         slug,
  //       },
  //       props: { page },
  //     };
  //   });
}

const { page } = Astro.props;
const { Content } = await render(page);
const { title, description, menu } = page.data;
---

<DocLayout title={title} description={description} section={menu as MenuSection}>
  <Content />
</DocLayout>
