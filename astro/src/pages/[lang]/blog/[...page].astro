---
import Layout from '@layouts/Layout.astro';
import { languages } from '@i18n/locales';
import { Container, Grid, Col } from '@components/primitives';
import { PostCard, Pagination, PageHead } from '@components/patterns';
import { getCollection } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = await getCollection('blog');

  return Object.keys(languages).flatMap((lang) => {
    const langPosts = allPosts
      .filter((post) => post.id.startsWith(`${lang}/`))
      .sort((a, b) => {
        const aFile = a.id.split('/').pop() ?? '';
        const bFile = b.id.split('/').pop() ?? '';
        return bFile.localeCompare(aFile);
      });

    return paginate(langPosts, { params: { lang }, pageSize: 6 });
  });
}

const { page } = Astro.props;
const { lang } = Astro.params;

function getDate(id: string) {
  const filename = id.split('/').pop() ?? id;
  const dateStr = filename.substring(0, 10);
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function getLabel(tags?: string) {
  const first = tags?.split(' ')[0] ?? '';
  return first.charAt(0).toUpperCase() + first.slice(1);
}
---

<Layout title="Express Blog">
  <Container>
    <PageHead
      title="Blog post"
      description="Stay tuned for details on new releases, enhancements, and everything you need to know to make the most of your Express applications. Let's dive into what's new!"
    />
    <Grid gap="4" align="stretch">
      {
        page.data.map((post) => {
          const authors = (post.data.authors ?? []).map((a) => ({
            src: a.github ? `https://github.com/${a.github}.png` : '',
            name: a.name ?? '',
          }));
          return (
            <Col xs={12} md={4} lg={4}>
              <PostCard
                href={`/${lang}/blog/${post.id.split('/').pop()}`}
                label={getLabel(post.data.tags)}
                title={post.data.title}
                coverSrc="/posts/sample-cover.png"
                authors={authors}
                avatarCaption={getDate(post.id)}
              />
            </Col>
          );
        })
      }
    </Grid>
    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </Container>
</Layout>
