---
/**
 * Express Documentation Index Page
 *
 * TODO: This is a temporary index page for the blog listing recent posts. This will be replaced with a proper blog layout in the future.
 */
import Layout from '@layouts/Layout.astro';
import { languages } from '@i18n/locales';
import { Container, Grid, Col } from '@/components/primitives';
import { PostCard } from '@components/patterns';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}
---

<Layout title="Express Blog">
  <Container>
    <PostCard
      size="lg"
      href="/blog/express-5-lts"
      label="Release"
      title="Express 5.1.0: Now the Default on npm with LTS Timeline"
      avatarSrc="/avatar/sample.png"
      avatarName="Wes Todd"
      avatarCaption="Mar 01, 2026"
    />
    <Grid gap="4">
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/security-releases-march-2026"
          label="Security"
          title="Security Releases: March 2026"
          avatarSrc="/avatar/sample.png"
          avatarName="Blake Embrey"
          avatarCaption="Mar 04, 2026"
        />
      </Col>
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/expressjs-is-joining-openjsf"
          label="News"
          title="Express.js is Joining the OpenJS Foundation"
          avatarSrc="/avatar/sample.png"
          avatarName="Doug Wilson"
          avatarCaption="Feb 14, 2026"
        />
      </Col>
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/express-and-nodejs-lts"
          label="LTS"
          title="Express and Node.js Long Term Support"
          avatarSrc="/avatar/sample.png"
          avatarName="Wes Todd"
          avatarCaption="Jan 20, 2026"
        />
      </Col>
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/migrate-to-express-5"
          label="Guide"
          title="How to Migrate Your App to Express 5"
          avatarSrc="/avatar/sample.png"
          avatarName="Blake Embrey"
          avatarCaption="Dec 10, 2025"
        />
      </Col>
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/expressjs-middleware-best-practices"
          label="Best Practices"
          title="Middleware Best Practices in Express"
          avatarSrc="/avatar/sample.png"
          avatarName="Doug Wilson"
          avatarCaption="Nov 28, 2025"
        />
      </Col>
      <Col xs={12} md={4} lg={4}>
        <PostCard
          size="md"
          href="/blog/express-performance-tips"
          label="Performance"
          title="Performance Tips for Express Applications"
          avatarSrc="/avatar/sample.png"
          avatarName="Wes Todd"
          avatarCaption="Nov 05, 2025"
        />
      </Col>
    </Grid>
  </Container>
</Layout>
