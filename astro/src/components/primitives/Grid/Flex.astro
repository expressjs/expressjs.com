---
/**
 * Flex Component
 *
 * Flexbox container for 1D layouts.
 * Use for simple directional layouts, navbars, stacks.
 *
 * @example
 * <Flex direction="column" gap="4" align="center">
 *   <div>Item 1</div>
 *   <div>Item 2</div>
 * </Flex>
 */

import type { HTMLAttributes } from 'astro/types';
import './Grid.css';

type FlexDirection = 'row' | 'column' | 'row-reverse' | 'column-reverse';
type FlexAlign = 'start' | 'center' | 'end' | 'stretch' | 'baseline';
type FlexJustify = 'start' | 'center' | 'end' | 'between' | 'around' | 'evenly';
type FlexWrap = 'nowrap' | 'wrap' | 'wrap-reverse';
type GapSize = '0' | '1' | '2' | '3' | '4' | '6' | '8' | '12' | '16';

export interface FlexProps {
  /** Flex direction */
  direction?: FlexDirection;
  /** Align items on cross axis */
  align?: FlexAlign;
  /** Justify content on main axis */
  justify?: FlexJustify;
  /** Flex wrap behavior */
  wrap?: FlexWrap;
  /** Gap between flex items */
  gap?: GapSize;
}

type Props = FlexProps & HTMLAttributes<'div'>;

const { direction = 'row', align, justify, wrap, gap, class: className, ...rest } = Astro.props;
---

<div
  class:list={[
    'flex',
    direction && `flex--${direction}`,
    align && `flex--align-${align}`,
    justify && `flex--justify-${justify}`,
    wrap && `flex--${wrap}`,
    gap && `flex--gap-${gap}`,
    className,
  ]}
  {...rest}
>
  <slot />
</div>
