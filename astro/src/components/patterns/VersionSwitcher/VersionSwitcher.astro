---
/**
 * VersionSwitcher Component
 *
 * A dropdown to switch between different versions of documentation.
 * Detects the current version from the URL or fallback to the default version.
 *
 * @example
 * <VersionSwitcher
 *   versions={[
 *     { id: 'v5', label: 'v5.x', isDefault: true },
 *     { id: 'v4', label: 'v4.x' },
 *   ]}
 *   defaultVersion="v5"
 *   currentPath="/en/docs/v5/getting-started"
 * />
 */

import './VersionSwitcher.css';
import { Icon } from 'astro-icon/components';
import { Flex, Select } from '@/components/primitives';
import type { SelectOption } from '@/components/primitives';
import type { VersionConfig, VersionSwitcherProps } from './types';

type Props = VersionSwitcherProps;

const { versions, defaultVersion, currentPath = '', class: className, ...rest } = Astro.props;

function getVersionFromPath(path: string, availableVersions: VersionConfig[]): string | null {
  for (const version of availableVersions) {
    if (path.includes(`/${version.id}/`)) {
      return version.id;
    }
  }
  return null;
}

const urlVersion = getVersionFromPath(currentPath, versions);
const selectedVersion = urlVersion || defaultVersion;

const selectOptions: SelectOption[] = versions.map((version) => ({
  value: version.id,
  label: version.label,
  selected: version.id === selectedVersion,
}));
---

<Flex
  align="center"
  justify="center"
  gap="2"
  class:list={['version-switcher', className]}
  data-version-switcher
  {...rest}
>
  <label class="version-switcher__label" for="version-select">
    <Icon name="ph:tag" size="16" color="var(--color-icon-secondary)" aria-hidden="true" />
    <span class="sr-only">API version</span>
  </label>
  <Select
    id="version-select"
    options={selectOptions}
    value={selectedVersion}
    size="md"
    variant="default"
    fullWidth
    data-version-select
    data-selected-version={selectedVersion}
    aria-label="Select API version"
  />
</Flex>
