---
import './Hero.css';
import { Code } from 'astro-expressive-code/components';
import { Icon } from 'astro-icon/components';
import { H1, Button, Container, Flex, BodyMd, Grid, Col } from '@/components/primitives';
import { getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const expressPackage = await getEntry('npm', 'express');
const EXPRESS_VERSION = expressPackage?.data.version ?? '5.x';
const INSTALL_COMMAND = 'npm install express --save';
const EXAMPLE_CODE = `const express = require('express')
const app = express()
const port = 3000

app.get('/', (req, res) => {
  res.send('Hello World!')
})

app.listen(port, () => {
  console.log(\`Example app listening on port \${port}\`)
})`;
---

<section class="hero">
  <div class="hero__bg-container">
    <canvas class="hero__canvas" aria-hidden="true"></canvas>
    <div class="hero__video-overlay"></div>
  </div>
  <Container>
    <div class="hero__content">
      <Flex align="end" gap="4">
        <div class="hero__logo">
          <Icon name="logo-express-black" class="hero__logo-icon--dark" />
          <Icon name="logo-express-white" class="hero__logo-icon--light" />
        </div>
        <BodyMd vMargin={false}>{EXPRESS_VERSION}</BodyMd>
      </Flex>

      <Grid>
        <Col xs={12} lg={6} class="hero__text-content">
          <H1 vMargin={false}>{t('hero.tagline')}</H1>
          <div class="hero__cta">
            <div class="hero__code">
              <Code code={INSTALL_COMMAND} />
            </div>
            <Button as="a" href="/en/5x/starter/installing" size="md" fullWidth>
              {t('hero.getStarted')}
              <Icon name="fluent:arrow-right-16-regular" size="16" />
            </Button>
          </div>
        </Col>
        <Col xs={12} lg={6}>
          <div class="hero__code hero__example-code">
            <Code code={EXAMPLE_CODE} lang="js" />
          </div>
        </Col>
      </Grid>
    </div>
  </Container>
</section>

<script>
  import { initHeroWebGL } from './hero-background';

  async function initHero() {
    const canvas = document.querySelector<HTMLCanvasElement>('.hero__canvas');
    if (!canvas) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduce-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 768px)');

    // Skip WebGL entirely on mobile
    if (isMobile.matches) return;

    const bg = await initHeroWebGL(canvas, prefersReducedMotion);
    if (!bg) return;

    // Only animate when the hero is visible in the viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            bg.play();
          } else {
            bg.pause();
          }
        });
      },
      { rootMargin: '80px' }
    );

    observer.observe(canvas);

    // Pause when the tab is hidden to save resources
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        bg.pause();
      } else {
        bg.play();
      }
    });
  }

  // Run init when the DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
