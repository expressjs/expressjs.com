---
import './Hero.css';
import { Code } from 'astro-expressive-code/components';
import { Icon } from 'astro-icon/components';
import { H1, Button, Container, Flex, BodyMd, Grid, Col } from '@/components/primitives';

const EXPRESS_VERSION = '5.2.1';
const INSTALL_COMMAND = 'npm install express --save';
const EXAMPLE_CODE = `const express = require('express')
const app = express()
const port = 3000

app.get('/', (req, res) => {
  res.send('Hello World!')
})

app.listen(port, () => {
  console.log(\`Example app listening on port \${port}\`)
})`;

interface Props {
  videoSrc?: string;
  videoSrcLight?: string;
  posterSrc?: string;
  posterSrcLight?: string;
}

const { videoSrc, videoSrcLight, posterSrc, posterSrcLight } = Astro.props;
---

<section class="hero">
  {
    videoSrc && (
      <div class="hero__video-container">
        <img class="hero__video-poster" src={posterSrc} alt="" aria-hidden="true" />
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          data-video-desktop={videoSrc}
          data-video-desktop-light={videoSrcLight}
          data-poster-dark={posterSrc}
          data-poster-light={posterSrcLight}
        >
          <source src={videoSrc} type="video/mp4" />
        </video>
        <div class="hero__video-overlay" />
        <button
          class="hero__video-control"
          type="button"
          aria-label="Pause background video"
          data-state="playing"
        >
          <Icon name="fluent:pause-16-filled" class="hero__video-control-pause" />
          <Icon name="fluent:play-16-filled" class="hero__video-control-play" />
        </button>
      </div>
    )
  }
  <Container>
    <div class="hero__content">
      <Flex align="end" gap="4">
        <div class="hero__logo">
          <Icon name="logo-express-black" class="hero__logo-icon--dark" />
          <Icon name="logo-express-white" class="hero__logo-icon--light" />
        </div>
        <BodyMd vMargin={false}>{EXPRESS_VERSION}</BodyMd>
      </Flex>

      <Grid>
        <Col xs={12} lg={6} class="hero__text-content">
          <H1 vMargin={false}>Fast, unopinionated, minimalist web framework for Node.js </H1>
          <div class="hero__cta">
            <div class="hero__code">
              <Code code={INSTALL_COMMAND} />
            </div>
            <Button as="a" href="/en/5x/starter/installing" size="md" fullWidth>
              Get Started
              <Icon name="fluent:arrow-right-16-regular" size="16" />
            </Button>
          </div>
        </Col>
        <Col xs={12} lg={6}>
          <div class="hero__code hero__example-code">
            <Code code={EXAMPLE_CODE} lang="js" />
          </div>
        </Col>
      </Grid>
    </div>
  </Container>
</section>

<script>
  function initHeroVideo() {
    const videoContainer = document.querySelector('.hero__video-container');
    if (!videoContainer) return;

    const video = videoContainer.querySelector('.hero__video') as HTMLVideoElement;
    if (!video) return;

    const controlButton = videoContainer.querySelector('.hero__video-control') as HTMLButtonElement;
    if (!controlButton) return;

    const posterImg = videoContainer.querySelector('.hero__video-poster') as HTMLImageElement;

    const videoDesktop = video.getAttribute('data-video-desktop');
    const videoDesktopLight = video.getAttribute('data-video-desktop-light');
    const posterDark = video.getAttribute('data-poster-dark');
    const posterLight = video.getAttribute('data-poster-light');

    const getCurrentTheme = (): 'light' | 'dark' => {
      const htmlElement = document.documentElement;
      const dataTheme = htmlElement.getAttribute('data-theme');

      if (dataTheme === 'light' || dataTheme === 'dark') {
        return dataTheme;
      }

      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };

    const getVideoSource = (): string | null => {
      const theme = getCurrentTheme();

      if (theme === 'light' && videoDesktopLight) return videoDesktopLight;

      return videoDesktop;
    };

    const getPosterSource = (): string | null => {
      const theme = getCurrentTheme();

      if (theme === 'light' && posterLight) {
        return posterLight;
      }

      return posterDark;
    };

    const updatePoster = () => {
      const newPosterSrc = getPosterSource();
      if (newPosterSrc && posterImg) {
        posterImg.src = newPosterSrc;
      }
    };

    const handleThemeChange = () => {
      const isNowMobile = window.innerWidth < 768;

      updatePoster();

      if (isNowMobile) return;

      const currentSrc = video.querySelector('source')?.src;
      const targetSrc = getVideoSource();

      if (currentSrc && targetSrc && !currentSrc.endsWith(targetSrc)) {
        const source = video.querySelector('source');
        if (source) {
          source.src = targetSrc;
          video.load();
          video.play().catch(() => {});
        }
      }
    };

    const themeObserver = new MutationObserver(handleThemeChange);
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    darkModeMediaQuery.addEventListener('change', handleThemeChange);

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      updatePoster();
      video.pause();
      video.removeAttribute('autoplay');
      controlButton.style.display = 'none';
      return;
    }

    const isMobile = window.innerWidth < 768;

    updatePoster();

    if (isMobile) {
      video.pause();
      video.removeAttribute('autoplay');
      controlButton.style.display = 'none';
      // Don't load video source to save bandwidth
      return;
    }

    const initialSource = getVideoSource();
    if (initialSource) {
      const source = video.querySelector('source');
      if (source) {
        source.src = initialSource;
        video.load();
      }
    }

    video.addEventListener('canplay', () => video.setAttribute('data-loaded', 'true'), {
      once: true,
    });

    const togglePlayPause = () => {
      if (video.paused) {
        video.play().catch(() => {});
        controlButton.setAttribute('data-state', 'playing');
        controlButton.setAttribute('aria-label', 'Pause background video');
      } else {
        video.pause();
        controlButton.setAttribute('data-state', 'paused');
        controlButton.setAttribute('aria-label', 'Play background video');
      }
    };

    controlButton.addEventListener('click', togglePlayPause);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.play().catch(() => {});
            observer.disconnect();
          }
        });
      },
      { rootMargin: '50px' }
    );

    observer.observe(video);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        video.pause();
        controlButton.setAttribute('data-state', 'paused');
        controlButton.setAttribute('aria-label', 'Play background video');
      } else {
        video.play().catch(() => {});
        controlButton.setAttribute('data-state', 'playing');
        controlButton.setAttribute('aria-label', 'Pause background video');
      }
    });

    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const isNowMobile = window.innerWidth < 768;

        updatePoster();

        if (isNowMobile) {
          video.pause();
          video.removeAttribute('autoplay');
          video.removeAttribute('data-loaded'); // hides video, making poster visible
          controlButton.style.display = 'none';
        } else {
          controlButton.style.display = 'flex';
          const currentSrc = video.querySelector('source')?.src;
          const targetSrc = getVideoSource();

          if (currentSrc && targetSrc && !currentSrc.endsWith(targetSrc)) {
            const source = video.querySelector('source');
            if (source) {
              source.src = targetSrc;
              video.load();
              video.play().catch(() => {});
            }
          }
        }
      }, 250);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroVideo);
  } else {
    initHeroVideo();
  }
</script>
