---
import type { MenuItem } from '@/config/types';
import { BodyMd } from '@/components/primitives';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '@/i18n/utils';
import { ui } from '@/i18n/ui';

interface Props {
  item: MenuItem & { href?: string };
  href: string;
  isActive: boolean;
  variant: 'root' | 'nested';
  type: 'link' | 'submenu';
  submenuId?: string;
  targetLevel?: number;
  showIcon?: boolean;
  lang: string;
}

const {
  item,
  href,
  isActive,
  variant,
  type,
  submenuId,
  targetLevel,
  showIcon = false,
  lang,
} = Astro.props;

const t = useTranslations(lang as keyof typeof ui);

// Translate label and ariaLabel if they start with 'menu.'
const translatedLabel = item.label.startsWith('menu.') ? t(item.label) : item.label;
const translatedAriaLabel = item.ariaLabel?.startsWith('menu.')
  ? t(item.ariaLabel)
  : item.ariaLabel;

// Root submenu items with href should render as links on tablet/desktop
const isRootSubmenuWithHref = type === 'submenu' && variant === 'root' && href;
---

{
  type === 'link' ? (
    <li>
      <a
        href={href}
        class:list={[
          'sidebar-nav-item',
          variant === 'nested' && 'sidebar-nav-item--nested',
          isActive && 'sidebar-nav-item--active',
        ]}
        aria-label={translatedAriaLabel}
        aria-current={isActive ? 'page' : undefined}
        data-omit-from={item.omitFrom?.join(',') || undefined}
      >
        {showIcon && item.icon && (
          <div class="sidebar-nav-icon">
            <Icon name={`fluent:${item.icon}`} size="24" color="var(--color-icon-primary)" />
          </div>
        )}
        <BodyMd vMargin={false} class="sidebar-nav-label">
          {translatedLabel}
        </BodyMd>
      </a>
    </li>
  ) : isRootSubmenuWithHref ? (
    <li>
      {/* Link for tablet/desktop - hidden on mobile */}
      <a
        href={href}
        class:list={[
          'sidebar-nav-item',
          'sidebar-nav-item--root-link',
          isActive && 'sidebar-nav-item--active',
        ]}
        aria-label={translatedAriaLabel}
        aria-current={isActive ? 'page' : undefined}
      >
        {showIcon && item.icon && (
          <div class="sidebar-nav-icon">
            <Icon name={`fluent:${item.icon}`} size="24" color="var(--color-icon-primary)" />
          </div>
        )}
        <BodyMd vMargin={false} class="sidebar-nav-label">
          {translatedLabel}
        </BodyMd>
      </a>
      {/* Button for mobile - hidden on tablet/desktop */}
      <button
        class:list={['sidebar-nav-item', 'sidebar-nav-item--root-submenu']}
        aria-label={translatedAriaLabel}
        aria-expanded="false"
        aria-controls={submenuId}
        type="button"
        data-submenu-trigger
        data-target-id={submenuId}
        data-target-level={targetLevel}
      >
        {showIcon && item.icon && (
          <div class="sidebar-nav-icon">
            <Icon name={`fluent:${item.icon}`} size="24" color="var(--color-icon-primary)" />
          </div>
        )}
        <BodyMd vMargin={false} class="sidebar-nav-label">
          {translatedLabel}
        </BodyMd>
        <Icon
          name="fluent:arrow-right-20-regular"
          size="16"
          color="var(--color-icon-secondary)"
          class="sidebar-nav-arrow"
          aria-hidden="true"
        />
      </button>
    </li>
  ) : (
    <li>
      <button
        class:list={[
          'sidebar-nav-item',
          variant === 'nested' && 'sidebar-nav-item--nested',
          type === 'submenu' && variant === 'nested' && 'sidebar-nav-item--submenu',
        ]}
        aria-label={translatedAriaLabel}
        aria-expanded="false"
        aria-controls={submenuId}
        type="button"
        data-submenu-trigger
        data-target-id={submenuId}
        data-target-level={targetLevel}
      >
        {showIcon && item.icon && (
          <div class="sidebar-nav-icon">
            <Icon name={`fluent:${item.icon}`} size="24" color="var(--color-icon-primary)" />
          </div>
        )}
        <BodyMd vMargin={false} class="sidebar-nav-label">
          {translatedLabel}
        </BodyMd>
        <Icon
          name="fluent:arrow-right-20-regular"
          size="16"
          color="var(--color-icon-secondary)"
          class="sidebar-nav-arrow"
          aria-hidden="true"
        />
      </button>
    </li>
  )
}
