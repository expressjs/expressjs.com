---
/**
 * Sidebar Component
 *
 * Navigation sidebar with:
 * - All menu levels pre-rendered at build time
 * - Sections with optional titles at any level
 * - Version switcher for versioned content
 * - Full accessibility support (focus trap, keyboard navigation, ARIA)
 * - Minimal JS for open/close and navigation animations only
 */

import './Sidebar.css';
import type { HTMLAttributes } from 'astro/types';
import { getLangFromUrl } from '@/i18n/utils';
import { mainMenu } from '@/config/main-menu';
import type { VersionConfig } from '@/components/patterns/VersionSwitcher/types';
import type { Menu } from '@/config/types';
import SidebarMenu from './SidebarMenu.astro';

type Props = HTMLAttributes<'div'> & {
  menu?: Menu;
  versions?: VersionConfig[];
  defaultVersion?: string;
};

const {
  menu = mainMenu,
  versions = [
    { id: 'v5', label: 'v5.x', isDefault: true },
    { id: 'v4', label: 'v4.x' },
    { id: 'v3', label: 'v3.x (deprecated)' },
  ],
  defaultVersion = 'v5',
  ...rest
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

function detectVersionFromUrl(): string {
  for (const version of versions) {
    if (currentPath.includes(`/${version.id}/`)) {
      return version.id;
    }
  }
  return defaultVersion;
}

const currentVersion = detectVersionFromUrl();
---

<div id="sidebarBackdrop" class="sidebar-backdrop" aria-hidden="true" data-sidebar-backdrop></div>

<aside
  id="sidebar"
  class="sidebar"
  role="dialog"
  aria-modal="true"
  aria-labelledby="sidebar-title"
  aria-hidden="true"
  data-sidebar
  data-lang={lang}
  data-current-path={currentPath}
  data-current-version={currentVersion}
  {...rest}
>
  <h2 id="sidebar-title" class="sr-only">Main menu</h2>

  <div class="sidebar-container" data-nav-container>
    <SidebarMenu
      menu={menu}
      level={0}
      title="Main Menu"
      lang={lang}
      currentPath={currentPath}
      version={currentVersion}
      versions={versions}
      defaultVersion={defaultVersion}
    />
  </div>

  <script>
    import './SidebarController';
  </script>
</aside>
