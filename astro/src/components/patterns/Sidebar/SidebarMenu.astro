---
/**
 * SidebarMenu Component
 *
 * Recursively renders menu levels statically at build time.
 */

import type { Menu, MenuItem } from '@/config/types';
import type { VersionConfig } from '@/components/patterns/VersionSwitcher/types';
import { Body, BodyMd, BodySm } from '@/components/primitives';
import { Icon } from 'astro-icon/components';
import { VersionSwitcher } from '@/components/patterns';

interface Props {
  menu: Menu;
  level: number;
  title?: string;
  lang: string;
  currentPath: string;
  basePath?: string;
  versioned?: boolean;
  version?: string;
  versions?: VersionConfig[];
  defaultVersion?: string;
  parentId?: string;
}

const {
  menu,
  level,
  lang,
  currentPath,
  basePath = '',
  versioned = false,
  version = 'v5',
  versions = [],
  defaultVersion = 'v5',
  parentId = 'root',
} = Astro.props;

/**
 * Resolve href with basePath and version
 */
function resolveHref(href: string): string {
  let fullPath = '';

  if (versioned && basePath) {
    fullPath = `/${lang}${basePath}/${version}${href}`;
  } else if (basePath) {
    fullPath = `/${lang}${basePath}${href}`;
  } else {
    fullPath = `/${lang}${href}`;
  }

  return fullPath;
}

/**
 * Check if item is a link (has href)
 */
function isLink(item: MenuItem): item is MenuItem & { href: string } {
  return 'href' in item && item.href !== undefined;
}

/**
 * Check if item has a submenu
 */
function hasSubmenu(item: MenuItem): item is MenuItem & { submenu: Menu } {
  return 'submenu' in item && item.submenu !== undefined;
}

/**
 * Generate unique ID for a menu item
 */
function getItemId(sectionIndex: number | null, itemIndex: number): string {
  if (sectionIndex !== null) {
    return `${parentId}-s${sectionIndex}-i${itemIndex}`;
  }
  return `${parentId}-i${itemIndex}`;
}

// Collect all submenus for recursive rendering
type SubmenuData = {
  menu: Menu;
  title: string;
  id: string;
  basePath: string;
  versioned: boolean;
  level: number;
};

const submenus: SubmenuData[] = [];

/**
 * Recursively collect all submenus from a menu, tracking their level
 */
function collectAllSubmenus(
  menuToScan: Menu,
  currentLevel: number,
  currentParentId: string,
  currentBasePath: string,
  currentVersioned: boolean
) {
  const collectFromItems = (items: MenuItem[], sectionIndex: number | null) => {
    items.forEach((item, itemIndex) => {
      if (hasSubmenu(item)) {
        const itemId =
          sectionIndex !== null
            ? `${currentParentId}-s${sectionIndex}-i${itemIndex}`
            : `${currentParentId}-i${itemIndex}`;
        const submenuId = `submenu-${itemId}`;
        const submenuBasePath = item.submenu.basePath || currentBasePath;
        const submenuVersioned = item.submenu.versioned ?? currentVersioned;

        submenus.push({
          menu: item.submenu,
          title: item.label,
          id: submenuId,
          basePath: submenuBasePath,
          versioned: submenuVersioned,
          level: currentLevel + 1,
        });

        // Recursively collect nested submenus
        collectAllSubmenus(
          item.submenu,
          currentLevel + 1,
          submenuId,
          submenuBasePath,
          submenuVersioned
        );
      }
    });
  };

  // Collect from sections
  menuToScan.sections?.forEach((section, sectionIndex) => {
    collectFromItems(section.items, sectionIndex);
  });

  // Collect from standalone items
  if (menuToScan.items) {
    collectFromItems(menuToScan.items, null);
  }
}

// Only collect all submenus at level 0
if (level === 0) {
  collectAllSubmenus(menu, level, parentId, basePath, versioned);
}

// Group submenus by level for rendering
const submenusByLevel = new Map<number, SubmenuData[]>();
submenus.forEach((submenu) => {
  const levelSubmenus = submenusByLevel.get(submenu.level) || [];
  levelSubmenus.push(submenu);
  submenusByLevel.set(submenu.level, levelSubmenus);
});

// Get sorted level numbers
const sortedLevels = Array.from(submenusByLevel.keys()).sort((a, b) => a - b);

/**
 * Resolve href for a submenu item (used in nested panel rendering)
 */
function resolveSubmenuHref(
  href: string,
  submenuBasePath: string,
  submenuVersioned: boolean
): string {
  let fullPath = '';

  if (submenuVersioned && submenuBasePath) {
    fullPath = `/${lang}${submenuBasePath}/${version}${href}`;
  } else if (submenuBasePath) {
    fullPath = `/${lang}${submenuBasePath}${href}`;
  } else {
    fullPath = `/${lang}${href}`;
  }

  return fullPath;
}

/**
 * Generate item ID for submenu items
 */
function getSubmenuItemId(
  submenuParentId: string,
  sectionIndex: number | null,
  itemIndex: number
): string {
  if (sectionIndex !== null) {
    return `${submenuParentId}-s${sectionIndex}-i${itemIndex}`;
  }
  return `${submenuParentId}-i${itemIndex}`;
}

/**
 * Check if a submenu contains a link matching the current path
 */
function submenuContainsCurrentPath(
  submenuMenu: Menu,
  submenuBasePath: string,
  submenuVersioned: boolean
): boolean {
  // Normalize path by removing trailing slash for comparison
  const normalizePath = (path: string) => path.replace(/\/$/, '');
  const normalizedCurrentPath = normalizePath(currentPath);

  const checkItems = (items: MenuItem[]): boolean => {
    for (const item of items) {
      if (isLink(item)) {
        const href = resolveSubmenuHref(item.href, submenuBasePath, submenuVersioned);
        if (normalizedCurrentPath === normalizePath(href)) {
          return true;
        }
      }
      // Also check nested submenus recursively
      if (hasSubmenu(item)) {
        const nestedBasePath = item.submenu.basePath || submenuBasePath;
        const nestedVersioned = item.submenu.versioned ?? submenuVersioned;
        if (submenuContainsCurrentPath(item.submenu, nestedBasePath, nestedVersioned)) {
          return true;
        }
      }
    }
    return false;
  };

  // Check sections
  for (const section of submenuMenu.sections || []) {
    if (checkItems(section.items)) {
      return true;
    }
  }

  // Check standalone items
  if (submenuMenu.items && checkItems(submenuMenu.items)) {
    return true;
  }

  return false;
}

/**
 * Calculate the initial active level based on current path
 * Returns the level of the deepest submenu that contains the current path
 */
function calculateInitialActiveLevel(): number {
  let activeLevel = 0;

  for (const submenu of submenus) {
    if (submenuContainsCurrentPath(submenu.menu, submenu.basePath, submenu.versioned)) {
      if (submenu.level > activeLevel) {
        activeLevel = submenu.level;
      }
    }
  }

  return activeLevel;
}

// Calculate initial active level at build time (only for level 0)
const initialActiveLevel = level === 0 ? calculateInitialActiveLevel() : 0;
---

{/* Root Level (level 0) */}
{
  level === 0 && (
    <div
      class="sidebar-column sidebar-root-column"
      data-nav-level={level}
      data-parent-id={parentId}
      data-initial-active-level={initialActiveLevel}
      aria-hidden="false"
    >
      <nav class="sidebar-nav" aria-label="Main navigation">
        <ul class="sidebar-nav-list">
          {menu.sections?.map((section, sectionIndex) => (
            <li class="sidebar-section" data-section-index={sectionIndex}>
              {section.title && <Body as="h3">{section.title}</Body>}
              <ul class="sidebar-section-list">
                {section.items.map((item, itemIndex) => {
                  const itemId = getItemId(sectionIndex, itemIndex);

                  if (isLink(item)) {
                    const href = resolveHref(item.href);
                    const isActive = currentPath === href;

                    return (
                      <li>
                        <a
                          href={href}
                          class:list={['sidebar-nav-item', isActive && 'sidebar-nav-item--active']}
                          aria-label={item.ariaLabel}
                          aria-current={isActive ? 'page' : undefined}
                        >
                          {item.icon && (
                            <div class="sidebar-nav-icon">
                              <Icon
                                name={`ph:${item.icon}`}
                                size="24"
                                color="var(--color-icon-primary)"
                              />
                            </div>
                          )}
                          <BodyMd vMargin={false} class="sidebar-nav-label">
                            {item.label}
                          </BodyMd>
                        </a>
                      </li>
                    );
                  } else if (hasSubmenu(item)) {
                    const submenuId = `submenu-${itemId}`;

                    return (
                      <li>
                        <button
                          class="sidebar-nav-item"
                          aria-label={item.ariaLabel}
                          aria-expanded="false"
                          aria-controls={submenuId}
                          type="button"
                          data-submenu-trigger
                          data-target-id={submenuId}
                          data-target-level={level + 1}
                        >
                          {item.icon && (
                            <div class="sidebar-nav-icon">
                              <Icon
                                name={`ph:${item.icon}`}
                                size="24"
                                color="var(--color-icon-primary)"
                              />
                            </div>
                          )}
                          <BodyMd vMargin={false} class="sidebar-nav-label">
                            {item.label}
                          </BodyMd>
                          <Icon
                            name="ph:arrow-right"
                            size="16"
                            color="var(--color-icon-secondary)"
                            class="sidebar-nav-arrow"
                            aria-hidden="true"
                          />
                        </button>
                      </li>
                    );
                  }
                  return null;
                })}
              </ul>
            </li>
          ))}
          {menu.items?.map((item, itemIndex) => {
            const itemId = getItemId(null, itemIndex);

            if (isLink(item)) {
              const href = resolveHref(item.href);
              const isActive = currentPath === href;

              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      'sidebar-nav-item',
                      'sidebar-nav-item--outer',
                      isActive && 'sidebar-nav-item--active',
                    ]}
                    aria-label={item.ariaLabel}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {item.icon && (
                      <div class="sidebar-nav-icon">
                        <Icon
                          name={`ph:${item.icon}`}
                          size="24"
                          color="var(--color-icon-primary)"
                        />
                      </div>
                    )}
                    <BodyMd vMargin={false} class="sidebar-nav-label">
                      {item.label}
                    </BodyMd>
                  </a>
                </li>
              );
            } else if (hasSubmenu(item)) {
              const submenuId = `submenu-${itemId}`;

              return (
                <li>
                  <button
                    class="sidebar-nav-item sidebar-nav-item--outer"
                    aria-label={item.ariaLabel}
                    aria-expanded="false"
                    aria-controls={submenuId}
                    type="button"
                    data-submenu-trigger
                    data-target-id={submenuId}
                    data-target-level={level + 1}
                  >
                    {item.icon && (
                      <div class="sidebar-nav-icon">
                        <Icon
                          name={`ph:${item.icon}`}
                          size="24"
                          color="var(--color-icon-primary)"
                        />
                      </div>
                    )}
                    <BodyMd vMargin={false} class="sidebar-nav-label">
                      {item.label}
                    </BodyMd>
                    <Icon
                      name="ph:arrow-right"
                      size="16"
                      color="var(--color-icon-secondary)"
                      class="sidebar-nav-arrow"
                      aria-hidden="true"
                    />
                  </button>
                </li>
              );
            }
            return null;
          })}
        </ul>
      </nav>
    </div>
  )
}

{/* Nested Levels - rendered only at level 0 */}
{/* Each level gets its own sidebar-column containing all nav panels for that level */}
{
  level === 0 && sortedLevels.length > 0 && (
    <div class="sidebar-nested" data-nested-levels-container>
      {sortedLevels.map((navLevel) => (
        <div
          class="sidebar-column sidebar-nested-column"
          data-nav-level={navLevel}
          aria-hidden="true"
        >
          {submenusByLevel.get(navLevel)?.map((submenu) => {
            const panelHasActiveItem = submenuContainsCurrentPath(
              submenu.menu,
              submenu.basePath,
              submenu.versioned
            );
            return (
              <div
                class:list={[
                  'sidebar-nav-panel',
                  panelHasActiveItem && 'sidebar-nav-panel--active',
                ]}
                data-parent-id={submenu.id}
                aria-hidden="true"
              >
                {submenu.versioned && versions.length > 0 && (
                  <VersionSwitcher
                    class="sidebar-version-switcher"
                    versions={versions}
                    defaultVersion={defaultVersion}
                    currentPath={currentPath}
                    aria-label="Select documentation version"
                    data-version-switcher
                  />
                )}
                <nav class="sidebar-nav" aria-label={`${submenu.title} navigation`}>
                  <button
                    class="sidebar-nav-back"
                    type="button"
                    aria-label={`Go back from ${submenu.title}`}
                    data-back-button
                    data-target-level={navLevel - 1}
                  >
                    <Icon
                      name="ph:arrow-line-left"
                      size="16"
                      color="var(--color-icon-primary)"
                      aria-hidden="true"
                    />
                    <Body as="h3" weight="bold" vMargin={false}>
                      {submenu.title}
                    </Body>
                  </button>
                  <div class="sidebar-nav-content">
                    {submenu.menu.sections?.map((section, sectionIndex) => (
                      <div class="sidebar-section" data-section-index={sectionIndex}>
                        {section.title && (
                          <Body as="h3" weight="bold">
                            {section.title}
                          </Body>
                        )}
                        <ul class="sidebar-section-list">
                          {section.items.map((item, itemIndex) => {
                            const itemId = getSubmenuItemId(submenu.id, sectionIndex, itemIndex);

                            if (isLink(item)) {
                              const href = resolveSubmenuHref(
                                item.href,
                                submenu.basePath,
                                submenu.versioned
                              );
                              const isActive = currentPath === href;

                              return (
                                <li>
                                  <a
                                    href={href}
                                    class:list={[
                                      'sidebar-nav-item',
                                      'sidebar-nav-item--nested',
                                      isActive && 'sidebar-nav-item--active',
                                    ]}
                                    aria-current={isActive ? 'page' : undefined}
                                  >
                                    <BodyMd vMargin={false}>{item.label}</BodyMd>
                                  </a>
                                </li>
                              );
                            } else if (hasSubmenu(item)) {
                              const submenuId = `submenu-${itemId}`;

                              return (
                                <li>
                                  <button
                                    class="sidebar-nav-item sidebar-nav-item--nested sidebar-nav-item--submenu"
                                    aria-expanded="false"
                                    aria-controls={submenuId}
                                    type="button"
                                    data-submenu-trigger
                                    data-target-id={submenuId}
                                    data-target-level={navLevel + 1}
                                  >
                                    <BodyMd vMargin={false}>{item.label}</BodyMd>
                                    <Icon
                                      name="ph:arrow-right"
                                      size="16"
                                      color="var(--color-icon-secondary)"
                                      class="sidebar-nav-arrow"
                                      aria-hidden="true"
                                    />
                                  </button>
                                </li>
                              );
                            }
                            return null;
                          })}
                        </ul>
                      </div>
                    ))}
                    {submenu.menu.items && submenu.menu.items.length > 0 && (
                      <ul class="sidebar-section-list">
                        {submenu.menu.items.map((item, itemIndex) => {
                          const itemId = getSubmenuItemId(submenu.id, null, itemIndex);

                          if (isLink(item)) {
                            const href = resolveSubmenuHref(
                              item.href,
                              submenu.basePath,
                              submenu.versioned
                            );
                            const isActive = currentPath === href;

                            return (
                              <li>
                                <a
                                  href={href}
                                  class:list={[
                                    'sidebar-nav-item',
                                    'sidebar-nav-item--nested',
                                    isActive && 'sidebar-nav-item--active',
                                  ]}
                                  aria-current={isActive ? 'page' : undefined}
                                >
                                  <span class="sidebar-nav-label">{item.label}</span>
                                </a>
                              </li>
                            );
                          } else if (hasSubmenu(item)) {
                            const submenuId = `submenu-${itemId}`;

                            return (
                              <li>
                                <button
                                  class="sidebar-nav-item sidebar-nav-item--nested sidebar-nav-item--submenu"
                                  aria-expanded="false"
                                  aria-controls={submenuId}
                                  type="button"
                                  data-submenu-trigger
                                  data-target-id={submenuId}
                                  data-target-level={navLevel + 1}
                                >
                                  <span class="sidebar-nav-label">{item.label}</span>
                                  <Icon
                                    name="ph:arrow-right"
                                    size="16"
                                    color="var(--color-icon-secondary)"
                                    class="sidebar-nav-arrow"
                                    aria-hidden="true"
                                  />
                                </button>
                              </li>
                            );
                          }
                          return null;
                        })}
                      </ul>
                    )}
                  </div>
                </nav>
              </div>
            );
          })}
        </div>
      ))}
    </div>
  )
}
