---
import type { Menu } from '@/config/types';
import type { VersionConfig } from '@/components/patterns/VersionSwitcher/types';
import { Body } from '@/components/primitives';
import { Icon } from 'astro-icon/components';
import { VersionSwitcher } from '@/components/patterns';
import SidebarNavItem from './SidebarNavItem.astro';
import {
  resolveHref,
  isLink,
  hasSubmenu,
  shouldOmitSection,
  filterItems,
  getItemId,
  collectAllSubmenus,
  submenuContainsCurrentPath,
  calculateInitialActiveLevel,
  groupSubmenusByLevel,
  type SubmenuData,
} from './utils';

interface Props {
  menu: Menu;
  level: number;
  title?: string;
  lang: string;
  currentPath: string;
  basePath?: string;
  versioned?: boolean;
  version?: string;
  versions?: VersionConfig[];
  defaultVersion?: string;
  parentId?: string;
}

const {
  menu,
  level,
  lang,
  currentPath,
  basePath = '',
  versioned = false,
  version = 'v5',
  versions = [],
  defaultVersion = 'v5',
  parentId = 'root',
} = Astro.props;

const submenus: SubmenuData[] = [];
if (level === 0) {
  collectAllSubmenus(menu, level, parentId, basePath, versioned, version, submenus);
}

const submenusByLevel = groupSubmenusByLevel(submenus);
const sortedLevels = Array.from(submenusByLevel.keys()).sort((a, b) => a - b);
const initialActiveLevel =
  level === 0 ? calculateInitialActiveLevel(submenus, currentPath, lang, version) : 0;

function getHref(href: string, itemBasePath = basePath, itemVersioned = versioned): string {
  return resolveHref(href, lang, itemBasePath, itemVersioned, version);
}
---

{
  level === 0 && (
    <div
      class="sidebar-column sidebar-root-column"
      data-nav-level={level}
      data-parent-id={parentId}
      data-initial-active-level={initialActiveLevel}
      aria-hidden="false"
    >
      <nav class="sidebar-nav" aria-label="Main navigation">
        <ul class="sidebar-nav-list">
          {menu.sections
            ?.filter((section) => !shouldOmitSection(section, version))
            .map((section, sectionIndex) => (
              <li class="sidebar-section" data-section-index={sectionIndex}>
                {section.title && <Body as="h3">{section.title}</Body>}
                <ul class="sidebar-section-list">
                  {filterItems(section.items, version).map((item, itemIndex) => {
                    const itemId = getItemId(parentId, sectionIndex, itemIndex);
                    const href = isLink(item) ? getHref(item.href) : '';
                    const isActive = currentPath === href;

                    return isLink(item) ? (
                      <SidebarNavItem
                        item={item}
                        href={href}
                        isActive={isActive}
                        variant="root"
                        type="link"
                        showIcon={true}
                      />
                    ) : hasSubmenu(item) ? (
                      <SidebarNavItem
                        item={item}
                        href=""
                        isActive={false}
                        variant="root"
                        type="submenu"
                        submenuId={`submenu-${itemId}`}
                        targetLevel={level + 1}
                        showIcon={true}
                      />
                    ) : null;
                  })}
                </ul>
              </li>
            ))}
          {filterItems(menu.items ?? [], version).map((item, itemIndex) => {
            const itemId = getItemId(parentId, null, itemIndex);
            const href = isLink(item) ? getHref(item.href) : '';
            const isActive = currentPath === href;

            return isLink(item) ? (
              <SidebarNavItem
                item={item}
                href={href}
                isActive={isActive}
                variant="root"
                type="link"
                showIcon={true}
              />
            ) : hasSubmenu(item) ? (
              <SidebarNavItem
                item={item}
                href=""
                isActive={false}
                variant="root"
                type="submenu"
                submenuId={`submenu-${itemId}`}
                targetLevel={level + 1}
                showIcon={true}
              />
            ) : null;
          })}
        </ul>
      </nav>
    </div>
  )
}

{
  level === 0 && sortedLevels.length > 0 && (
    <div class="sidebar-nested" data-nested-levels-container>
      {sortedLevels.map((navLevel) => (
        <div
          class="sidebar-column sidebar-nested-column"
          data-nav-level={navLevel}
          aria-hidden="true"
        >
          {submenusByLevel.get(navLevel)?.map((submenu) => {
            const panelHasActiveItem = submenuContainsCurrentPath(
              submenu.menu,
              submenu.basePath,
              submenu.versioned,
              currentPath,
              lang,
              version
            );
            return (
              <div
                class:list={[
                  'sidebar-nav-panel',
                  panelHasActiveItem && 'sidebar-nav-panel--active',
                ]}
                data-parent-id={submenu.id}
                aria-hidden="true"
              >
                {submenu.versioned && versions.length > 0 && (
                  <VersionSwitcher
                    class="sidebar-version-switcher"
                    versions={versions}
                    defaultVersion={defaultVersion}
                    currentPath={currentPath}
                    aria-label="Select documentation version"
                    data-version-switcher
                  />
                )}
                <nav class="sidebar-nav" aria-label={`${submenu.title} navigation`}>
                  <button
                    class="sidebar-nav-back"
                    type="button"
                    aria-label={`Go back from ${submenu.title}`}
                    data-back-button
                    data-target-level={navLevel - 1}
                  >
                    <Icon
                      name="ph:arrow-line-left"
                      size="16"
                      color="var(--color-icon-primary)"
                      aria-hidden="true"
                    />
                    <Body as="h3" weight="bold" vMargin={false}>
                      {submenu.title}
                    </Body>
                  </button>
                  <div class="sidebar-nav-content">
                    {submenu.menu.sections
                      ?.filter((section) => !shouldOmitSection(section, version))
                      .map((section, sectionIndex) => (
                        <div class="sidebar-section" data-section-index={sectionIndex}>
                          {section.title && (
                            <Body as="h3" weight="bold">
                              {section.title}
                            </Body>
                          )}
                          <ul class="sidebar-section-list">
                            {filterItems(section.items, version).map((item, itemIndex) => {
                              const itemId = getItemId(submenu.id, sectionIndex, itemIndex);
                              const href = isLink(item)
                                ? getHref(item.href, submenu.basePath, submenu.versioned)
                                : '';
                              const isActive = currentPath === href;

                              return isLink(item) ? (
                                <SidebarNavItem
                                  item={item}
                                  href={href}
                                  isActive={isActive}
                                  variant="nested"
                                  type="link"
                                />
                              ) : hasSubmenu(item) ? (
                                <SidebarNavItem
                                  item={item}
                                  href=""
                                  isActive={false}
                                  variant="nested"
                                  type="submenu"
                                  submenuId={`submenu-${itemId}`}
                                  targetLevel={navLevel + 1}
                                />
                              ) : null;
                            })}
                          </ul>
                        </div>
                      ))}
                    {submenu.menu.items && filterItems(submenu.menu.items, version).length > 0 && (
                      <ul class="sidebar-section-list">
                        {filterItems(submenu.menu.items, version).map((item, itemIndex) => {
                          const itemId = getItemId(submenu.id, null, itemIndex);
                          const href = isLink(item)
                            ? getHref(item.href, submenu.basePath, submenu.versioned)
                            : '';
                          const isActive = currentPath === href;

                          return isLink(item) ? (
                            <SidebarNavItem
                              item={item}
                              href={href}
                              isActive={isActive}
                              variant="nested"
                              type="link"
                            />
                          ) : hasSubmenu(item) ? (
                            <SidebarNavItem
                              item={item}
                              href=""
                              isActive={false}
                              variant="nested"
                              type="submenu"
                              submenuId={`submenu-${itemId}`}
                              targetLevel={navLevel + 1}
                            />
                          ) : null;
                        })}
                      </ul>
                    )}
                  </div>
                </nav>
              </div>
            );
          })}
        </div>
      ))}
    </div>
  )
}
