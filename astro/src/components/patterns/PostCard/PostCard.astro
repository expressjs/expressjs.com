---
/**
 * PostCard Pattern Component
 *
 * An article card with a label, title, and author avatar.
 * Available in two sizes: medium and large.
 *
 * @example — Large (default)
 * <PostCard
 *   size="lg"
 *   href="/blog/secure-express-app"
 *   label="Security"
 *   title="How to secure your Express app"
 *   coverSrc="/images/cover.jpg"
 *   avatarSrc="/images/author.jpg"
 *   avatarName="John Doe"
 *   avatarCaption="Jun 05, 2025"
 * />
 *
 * @example — Medium
 * <PostCard
 *   size="md"
 *   href="/blog/express-5"
 *   label="Release"
 *   title="Express 5.0 is here"
 *   coverSrc="/images/cover.jpg"
 *   avatarSrc="/images/author.jpg"
 *   avatarName="Jane Smith"
 *   avatarCaption="Mar 04, 2026"
 * />
 */
import './PostCard.css';
import type { HTMLAttributes } from 'astro/types';
import { H3, Avatar, Tag } from '@components/primitives';

interface Props extends HTMLAttributes<'article'> {
  href: string;
  label: string;
  title: string;
  coverSrc?: string;
  coverAlt?: string;
  avatarSrc: string;
  avatarAlt?: string;
  avatarName: string;
  avatarCaption?: string;
}

const {
  href,
  label,
  title,
  coverSrc,
  coverAlt = '',
  avatarSrc,
  avatarAlt = '',
  avatarName,
  avatarCaption,
  class: className,
  ...rest
} = Astro.props;
---

<article class:list={['post-card', className]} {...rest}>
  <a href={href} class="post-card__link">
    <div>
      {coverSrc && <img class="post-card__cover" src={coverSrc} alt={coverAlt || ''} />}
      <Tag class="post-card__label">{label}</Tag>
      <H3 as="h2" vMargin={false} class="post-card__title">
        {title}
      </H3>
    </div>
    <Avatar
      src={avatarSrc}
      alt={avatarAlt}
      name={avatarName}
      caption={avatarCaption}
      size="md"
      class="post-card__avatar"
    />
  </a>
</article>
