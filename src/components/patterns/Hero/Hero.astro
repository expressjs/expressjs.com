---
import './Hero.css';
import { Code } from 'astro-expressive-code/components';
import { Icon } from 'astro-icon/components';
import { H1, Button, Container, Flex, BodyMd, Grid, Col } from '@/components/primitives';
import { getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { Image } from 'astro:assets';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const expressPackage = await getEntry('npm', 'express');
const EXPRESS_VERSION = expressPackage?.data.version ?? '5.x';
const INSTALL_COMMAND = 'npm install express --save';
const EXAMPLE_CODE = `const express = require('express')
const app = express()
const port = 3000

app.get('/', (req, res) => {
  res.send('Hello World!')
})

app.listen(port, () => {
  console.log(\`Example app listening on port \${port}\`)
})`;
---

<section class="hero">
  <div class="hero__bg-container">
    <canvas class="hero__canvas" aria-hidden="true"></canvas>
    <div class="hero__video-overlay"></div>
  </div>
  <Container>
    <div class="hero__content">
      <Flex align="end" gap="4" data-testid="hero-brand">
        <div class="hero__logo">
          <Image
            src="/images/logos/express-kawaii.webp"
            alt={t('hero.kawaiiLogoAlt')}
            class="hero__logo-kawaii"
            width={400}
            height={225}
            loading="lazy"
            data-testid="logo-kawaii"
          />
          <Icon
            name="logo-express-black"
            class="hero__logo-icon--dark hero__logo-default"
            data-testid="logo-standard"
          />
          <Icon
            name="logo-express-white"
            class="hero__logo-icon--light hero__logo-default"
            data-testid="logo-standard"
          />
        </div>
        <BodyMd vMargin={false}>{EXPRESS_VERSION}</BodyMd>
      </Flex>

      <Grid>
        <Col xs={12} lg={6} class="hero__text-content">
          <H1 vMargin={false}>{t('hero.tagline')}</H1>
          <div class="hero__cta">
            <div class="hero__code" data-testid="install-command">
              <Code code={INSTALL_COMMAND} lang="plaintext" />
            </div>
            <Button as="a" href="/en/5x/starter/installing" size="md" fullWidth>
              {t('hero.getStarted')}
              <Icon name="fluent:arrow-right-16-regular" size="16" />
            </Button>
          </div>
        </Col>
        <Col xs={12} lg={6}>
          <div class="hero__code hero__example-code" data-testid="example-code">
            <Code code={EXAMPLE_CODE} lang="js" />
          </div>
        </Col>
      </Grid>
    </div>
  </Container>
</section>

<script>
  /**
   * Import immediately — module is small (~6KB) and shader compilation is async.
   * initHeroWebGL renders the first frame during init (in resize()),
   * so the arc appears as soon as shaders compile — no image fallback needed.
   *
   * Manages the WebGL background lifecycle.
   * Consolidates IntersectionObserver, Visibility API, and Motion preferences
   * into a single state machine to avoid conflicting play/pause calls.
   */
  import('./hero-background').then(({ initHeroWebGL }) => {
    const canvas = document.querySelector<HTMLCanvasElement>('.hero__canvas');
    if (!canvas) return;

    const isMobile = window.matchMedia('(max-width: 768px)');
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    initHeroWebGL(canvas, isMobile.matches || motionQuery.matches).then((bg) => {
      if (!bg) return;

      let isIntersecting = true;

      function sync() {
        // Only run the animation loop if:
        // 1. Not on mobile (performance)
        // 2. User hasn't requested reduced motion
        // 3. Element is in/near the viewport
        // 4. Tab is currently active
        const shouldAnimate =
          !isMobile.matches && !motionQuery.matches && isIntersecting && !document.hidden;

        if (shouldAnimate) {
          bg!.play();
        } else {
          bg!.pause();
        }
      }

      // Lifecycle Listeners
      const observer = new IntersectionObserver(
        (entries) => {
          isIntersecting = entries[0].isIntersecting;
          sync();
        },
        { rootMargin: '80px' }
      );
      observer.observe(canvas);

      document.addEventListener('visibilitychange', sync);
      motionQuery.addEventListener('change', sync);
      isMobile.addEventListener('change', sync);

      // Initialization
      // Trigger sync immediately so the background appears as soon as
      // the WebGL context and shaders are ready.
      sync();
    });
  });
</script>
