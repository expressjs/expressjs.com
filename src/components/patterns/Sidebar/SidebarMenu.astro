---
import type { Menu, VersionPrefix } from '@/config/types';
import type { VersionConfig } from '@/components/patterns/VersionSwitcher/types';
import type { LanguageCode } from '@/i18n/locales';
import { Body } from '@/components/primitives';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { VersionSwitcher } from '@/components/patterns';
import { useTranslations } from '@/i18n/utils';
import { DEFAULT_VERSION } from '@/config/versions';
import SidebarItemsList from './SidebarItemsList.astro';
import {
  shouldOmitSection,
  collectAllSubmenus,
  submenuContainsCurrentPath,
  calculateInitialActiveLevel,
  groupSubmenusByLevel,
  type SubmenuData,
} from './utils';

interface Props {
  menu: Menu;
  level: number;
  title?: string;
  lang: LanguageCode;
  currentPath: string;
  basePath?: string;
  versioned?: VersionPrefix[];
  version?: string;
  versions?: VersionConfig[];
  defaultVersion?: string;
  parentId?: string;
}

const {
  menu,
  level,
  lang,
  currentPath,
  basePath = '',
  versioned = [],
  version = DEFAULT_VERSION,
  versions = [],
  defaultVersion = DEFAULT_VERSION,
  parentId = 'root',
} = Astro.props;

const t = useTranslations(lang);

if (level !== 0) return null;

const submenus: SubmenuData[] = [];
collectAllSubmenus(menu, level, parentId, basePath, versioned, version, submenus);

const submenusByLevel = groupSubmenusByLevel(submenus);
const sortedLevels = [...submenusByLevel.keys()].sort((a, b) => a - b);
const initialActiveLevel = calculateInitialActiveLevel(submenus, currentPath, lang, version);

const filteredSections =
  menu.sections?.filter((section) => !shouldOmitSection(section, version)) ?? [];

const commonItemsListProps = {
  currentPath,
  lang,
  basePath,
  versioned,
  version,
};
---

<div
  class="sidebar-column sidebar-root-column"
  data-nav-level={level}
  data-parent-id={parentId}
  data-initial-active-level={initialActiveLevel}
  aria-hidden="false"
>
  <nav class="sidebar-nav" aria-label={t('nav.mainNavigation')}>
    <ul class="sidebar-nav-list">
      <li class="sidebar-logo-item">
        <a href={`/${lang}/`} class="logo-link sidebar-nav-item" aria-label={t('nav.home')}>
          <Image
            src="/images/logos/express-kawaii.webp"
            alt="Express.js kawaii logo"
            class="logo logo-kawaii"
            width={40}
            height={40}
          />
          <Icon name="logo-dark" class="logo logo-dark logo-default" />
          <Icon name="logo-light" class="logo logo-light logo-default" />
        </a>
      </li>
      {
        filteredSections.map((section, sectionIndex) => (
          <li class="sidebar-section">
            {section.title && <Body as="h3">{t(section.title)}</Body>}
            <ul class="sidebar-section-list">
              <SidebarItemsList
                items={section.items}
                parentId={parentId}
                sectionIndex={sectionIndex}
                {...commonItemsListProps}
                variant="root"
                showIcon={true}
                targetLevel={level + 1}
              />
            </ul>
          </li>
        ))
      }
      <SidebarItemsList
        items={menu.items ?? []}
        parentId={parentId}
        sectionIndex={null}
        variant="root"
        showIcon={true}
        targetLevel={level + 1}
        {...commonItemsListProps}
      />
    </ul>
  </nav>
</div>

{
  sortedLevels.length > 0 && (
    <div class="sidebar-nested" data-nested-levels-container>
      <div class="sidebar-nested-inner">
        {sortedLevels.map((navLevel) => (
          <div
            class="sidebar-column sidebar-nested-column"
            data-nav-level={navLevel}
            aria-hidden="true"
          >
            {submenusByLevel.get(navLevel)?.map((submenu) => {
              const panelHasActiveItem = submenuContainsCurrentPath(
                submenu.menu,
                submenu.basePath,
                submenu.versioned,
                currentPath,
                lang,
                version
              );
              const availableVersions =
                submenu.versioned.length > 0
                  ? versions.filter((v) => submenu.versioned.includes(v.id as VersionPrefix))
                  : [];
              const filteredSubmenuSections =
                submenu.menu.sections?.filter((section) => !shouldOmitSection(section, version)) ??
                [];

              return (
                <div
                  class:list={[
                    'sidebar-nav-panel',
                    panelHasActiveItem && 'sidebar-nav-panel--active',
                  ]}
                  data-parent-id={submenu.id}
                  aria-hidden="true"
                >
                  {availableVersions.length > 0 && (
                    <VersionSwitcher
                      class="sidebar-version-switcher"
                      versions={availableVersions}
                      defaultVersion={defaultVersion}
                      currentPath={currentPath}
                      aria-label="Select documentation version"
                      data-version-switcher
                    />
                  )}
                  <nav class="sidebar-nav" aria-label={`${t(submenu.title)} navigation`}>
                    <button
                      class="sidebar-nav-back"
                      type="button"
                      aria-label={`Go back from ${t(submenu.title)}`}
                      data-back-button
                      data-target-level={navLevel - 1}
                    >
                      <Icon
                        name="fluent:arrow-export-rtl-20-regular"
                        size="16"
                        color="var(--color-icon-primary)"
                        aria-hidden="true"
                      />
                      <Body as="span" weight="bold" vMargin={false}>
                        {t(submenu.title)}
                      </Body>
                    </button>
                    <div class="sidebar-nav-content">
                      {filteredSubmenuSections.map((section, sectionIndex) => (
                        <div class="sidebar-section" data-section-index={sectionIndex}>
                          {section.title && (
                            <Body as="h3" weight="bold">
                              {t(section.title)}
                            </Body>
                          )}
                          <ul class="sidebar-section-list">
                            <SidebarItemsList
                              items={section.items}
                              parentId={submenu.id}
                              sectionIndex={sectionIndex}
                              currentPath={currentPath}
                              lang={lang}
                              basePath={submenu.basePath}
                              versioned={submenu.versioned}
                              version={version}
                              variant="nested"
                              showIcon={false}
                              targetLevel={navLevel + 1}
                            />
                          </ul>
                        </div>
                      ))}
                      {(submenu.menu.items?.length ?? 0) > 0 && (
                        <ul class="sidebar-section-list">
                          <SidebarItemsList
                            items={submenu.menu.items!}
                            parentId={submenu.id}
                            sectionIndex={null}
                            currentPath={currentPath}
                            lang={lang}
                            basePath={submenu.basePath}
                            versioned={submenu.versioned}
                            version={version}
                            variant="nested"
                            showIcon={false}
                            targetLevel={navLevel + 1}
                          />
                        </ul>
                      )}
                    </div>
                  </nav>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  )
}
